from aiogram import Router, F
from aiogram.types import Message

router = Router()

@router.message(F.text.lower() == "помощь")
async def cmd_help(message: Message):
    text = (
        "🆘 *Доступные команды:*\n\n"
        "• `Статистика` — показать текущие показатели\n"
        "• `Часовой пояс` — изменить часовой пояс (формат `+3`)\n"
        "• `Перезагрузка` — удалить все данные и начать заново\n"
        "• `Помощь` — показать это сообщение\n\n"
        "📌 *Окна:*\n"
        "🌅 Утро: 6:00 – 9:00 — повторяем цель\n"
        "🌇 Вечер: 21:00 – 24:00 — отчёт о шагах\n\n"
        "✨ *Юбилеи:*\n"
        "• 8-й день — поздравление\n"
        "• 21-й день — поздравление\n"
        "• 100-е повторение цели — поздравление"
    )
    await message.answer(text, parse_mode="Markdown")